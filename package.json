{
  "name": "@backtest/monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @backtest/api dev\" \"pnpm --filter @backtest/frontend dev\" \"pnpm --filter @backtest/admin dev\"",
    "dev:backend": "pnpm --filter @backtest/api dev",
    "dev:frontend": "pnpm --filter @backtest/frontend dev",
    "dev:admin": "pnpm --filter @backtest/admin dev",
    "build": "pnpm --filter @backtest/api typecheck && pnpm --filter @backtest/frontend build && pnpm --filter @backtest/admin build",
    "build:backend": "pnpm --filter @backtest/api typecheck",
    "build:frontend": "pnpm --filter @backtest/frontend build",
    "build:admin": "pnpm --filter @backtest/admin build",
    "typecheck": "pnpm --filter @backtest/api typecheck && pnpm --filter @backtest/frontend typecheck && pnpm --filter @backtest/admin typecheck",
    "lint": "pnpm --filter @backtest/frontend lint && pnpm --filter @backtest/admin lint",
    "check": "pnpm typecheck && pnpm lint",
    "deploy:backend": "bash scripts/deploy-backend.sh",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "deploy:admin": "bash scripts/deploy-admin.sh",
    "deploy:all": "bash scripts/deploy-backend.sh && bash scripts/deploy-frontend.sh && bash scripts/deploy-admin.sh",
    "infra:preview": "pnpm --filter @backtest/infra preview",
    "infra:up": "pnpm --filter @backtest/infra up",
    "infra:destroy": "pnpm --filter @backtest/infra destroy"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0"
}
