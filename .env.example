# Environment Configuration Template

# Copy this file to services/backend/.dev.vars for local development
# For production, set these as Cloudflare Worker secrets

# Database
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Authentication
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:8788
FRONTEND_ORIGIN=http://localhost:5173

# Admin
INGESTION_ADMIN_SECRET=your-admin-secret

# ClickHouse
CLICKHOUSE_URL=https://your-instance.clickhouse.cloud:8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=your-password
CLICKHOUSE_DB=market_data

# CCXT Configuration
CCXT_EXCHANGE=binance
CCXT_DELAY_MS=1500
CCXT_BATCH_COOLDOWN_MS=120000
CCXT_MAX_RETRIES=3

# Yahoo Finance Configuration
YFINANCE_DELAY_MS=1000
YFINANCE_BATCH_COOLDOWN_MS=300000
YFINANCE_MAX_RETRIES=3
