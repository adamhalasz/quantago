{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "lib": [
            "ES2022",
            "WebWorker"
        ],
        "types": [
            "@cloudflare/workers-types"
        ],
        "isolatedModules": true,
        "noEmit": true
    },
    "include": [
        "src/**/*.ts",
        "../../strategies/**/*.ts",
        "../../strategies/**/*.json"
    ]
}