{
  "name": "@quantago/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "pnpm --dir ../backend dev",
    "build": "tsc -b && vite build",
    "build:api": "pnpm --dir ../backend typecheck",
    "lint": "eslint .",
