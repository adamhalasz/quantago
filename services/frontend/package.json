    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "apexcharts": "^5.3.5",
    "axios": "^1.12.2",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
